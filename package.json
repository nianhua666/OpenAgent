{
  "name": "openagent",
  "version": "3.0.12",
  "description": "OpenAgent - 支持 AI 对话、账号管理、托管 MCP / Skills 与 Live2D 桌面协作的桌面应用",
  "author": "年华",
  "license": "MIT",
  "homepage": "https://github.com/nianhua666/OpenAgent#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nianhua666/OpenAgent.git"
  },
  "keywords": [
    "electron",
    "vue3",
    "typescript",
    "openagent",
    "账号管理",
    "mcp"
  ],
  "bugs": {
    "url": "https://github.com/nianhua666/OpenAgent/issues"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:clean": "node scripts/build-clean.cjs",
    "smoke:routes": "node scripts/smoke-routes.cjs",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "npm run rebuild:native",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder --config electron-builder.config.cjs",
    "electron:build:clean": "npm run build:clean && npm run electron:build",
    "electron:preview": "npm run build && node scripts/run-electron.cjs .",
    "check:electron-ui": "npm run build && node scripts/check-electron-ui.cjs",
    "check:chrome-automation": "node scripts/check-chrome-automation.cjs",
    "check:live2d": "npm run build && node scripts/run-electron.cjs . --live2d-diagnose",
    "check:sub2api": "node scripts/check-sub2api.cjs",
    "release:publish": "node scripts/publish-release.cjs",
    "electron:release": "npm run electron:build:clean && npm run release:publish"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "fuse.js": "^7.0.0",
    "kokoro-js-zh": "^2.1.7",
    "monaco-editor": "^0.52.2",
    "msedge-tts": "^2.0.4",
    "node-pty": "^1.1.0",
    "oh-my-live2d": "^0.19.3",
    "pinia": "^2.1.7",
    "uuid": "^9.0.0",
    "vue": "^3.4.21",
    "vue-echarts": "^6.6.9",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "sass": "^1.71.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6"
  },
  "build": {}
}
